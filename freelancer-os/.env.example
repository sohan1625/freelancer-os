# Environment Variables Example for Freelancer OS Backend
# Copy this file to .env and fill in your actual values
# IMPORTANT: .env is in .gitignore and should NEVER be committed

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=freelancer_os
DB_USERNAME=postgres
DB_PASSWORD=your_secure_postgres_password_here

# ==========================================
# JWT CONFIGURATION
# ==========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_generated_jwt_secret_min_32_chars_here
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ==========================================
# EMAIL CONFIGURATION (Gmail)
# ==========================================
# Use Gmail App Password: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_16char_gmail_app_password_here

# ==========================================
# SERVER CONFIGURATION
# ==========================================
SERVER_PORT=8081
# Use 127.0.0.1 for local development
# Use 0.0.0.0 only when needed (Docker)
SERVER_ADDRESS=127.0.0.1

# ==========================================
# JPA/HIBERNATE CONFIGURATION
# ==========================================
# Development: update
# Production: validate
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# ==========================================
# APPLICATION PROFILE
# ==========================================
# dev, test, or prod
SPRING_PROFILES_ACTIVE=dev
